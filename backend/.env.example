# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # sk_test_... en développement
STRIPE_WEBHOOK_SECRET=whsec_...        # obtenu via: stripe listen --forward-to localhost:4000/api/stripe/webhook
STRIPE_SUCCESS_URL=https://www.xn--trouv-fsa.fr/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://www.xn--trouv-fsa.fr/tarifs
STRIPE_PORTAL_RETURN_URL=https://www.xn--trouv-fsa.fr/compte

# ─── ClickHouse (VPS Hetzner ~5€/mois) ──────────────────────────────────────
CLICKHOUSE_HOST=http://YOUR_VPS_IP:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_strong_password
CLICKHOUSE_DATABASE=trouve

# ─── Upstash Redis (cache — free tier) ───────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...             # console.anthropic.com → API Keys

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
