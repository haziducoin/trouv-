# Supabase (service role — secret, jamais côté client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Providers de recherche (mêmes clés que le pipeline Vercel existant)
EXA_API_KEY=
BRAVE_API_KEY=

# LLM open source gratuit — créer une clé sur https://console.groq.com (tier gratuit)
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile

# Secret partagé avec le proxy Vercel api/enrich-crew.ts (générer : openssl rand -hex 32)
ENRICH_SERVICE_SECRET=
